    "node-system-prompt": {
      "id": "node-system-prompt",
      "name": "🧠 Системный промт",
      "group": "2. AI-Ядро",
      "content": "Ядро генератора КП.\n\nИнструкция: «Ты — генератор коммерческих предложений. На основе входного брифинга создавай структурированное, профессиональное и правдивое КП на русском языке. Не выдумывай отсутствующие данные. Если информации не хватает, явно отмечай это.»\n\nСтиль: деловой, ясный, краткий, без воды.",
      "color": "#15803d",
      "position": { "x": -560, "y": -270 },
      "size": { "w": 720, "h": 260 },
      "parentId": "layer-ai-core",
      "snapToGrid": true
    },
