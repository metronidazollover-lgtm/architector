      "color": "#15803d",
      "position": { "x": -560, "y": 90 },
      "size": { "w": 720, "h": 260 },
      "parentId": "layer-ai-core",
      "snapToGrid": true
    },
    "node-section-generator": {
      "id": "node-section-generator",
      "name": "⚙️ Генератор секций КП",
      "group": "2. AI-Ядро",
      "content": "Создаёт все 9 секций КП параллельно.\n\nКаждая секция привязана к данным из брифа и результатам анализа контекста. Если данных нет — явно помечает допущения.\n\nРаздаёт задачи по трём потокам:\n→ Шапка (заголовок, резюме, понимание)\n→ Решение (описание, работы, сроки)\n→ Коммерция (стоимость, от клиента, итог)",
